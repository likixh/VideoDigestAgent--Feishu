# ──────────────────────────────────────────────
# YouTube Channels (comma-separated handles, without @)
# ──────────────────────────────────────────────
YOUTUBE_CHANNELS=RhinoFinance,MeetKevin,StockMoe

# YouTube Data API v3 key (required)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ──────────────────────────────────────────────
# LLM Provider: gemini | openai | anthropic
# ──────────────────────────────────────────────
LLM_PROVIDER=gemini

# Google Gemini (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional — only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (optional — only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ──────────────────────────────────────────────
# Summary language(s) — up to 2, comma-separated
# Examples: "English", "Chinese", "English,Chinese", "Japanese,English"
# ──────────────────────────────────────────────
SUMMARY_LANGUAGES=English

# Verify summary accuracy with a second LLM pass (true/false)
# Improves accuracy but doubles LLM cost per language
VERIFY_SUMMARY=false

# ──────────────────────────────────────────────
# Email settings (using Gmail SMTP as default)
# ──────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here
RECIPIENT_EMAIL=your_email@gmail.com

# ──────────────────────────────────────────────
# Polling interval in seconds (default: 3600 = 1 hour)
# ──────────────────────────────────────────────
POLL_INTERVAL=3600
