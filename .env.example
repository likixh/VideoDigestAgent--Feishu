# ──────────────────────────────────────────────
# YouTube Channels (comma-separated handles, without @)
# ──────────────────────────────────────────────
YOUTUBE_CHANNELS=RhinoFinance

# YouTube Data API v3 key (required)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ──────────────────────────────────────────────
# Bilibili (optional — set BILIBILI_ENABLED=true to activate)
# Monitors Bilibili user spaces for new video uploads.
# Requires browser cookies for transcript access.
# ──────────────────────────────────────────────
BILIBILI_ENABLED=false
# Comma-separated Bilibili user IDs (numeric UIDs from user profile URLs)
BILIBILI_USERS=
# Browser cookies (get from browser DevTools after logging into bilibili.com)
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=

# ──────────────────────────────────────────────
# LLM Provider: gemini | openai | anthropic
# ──────────────────────────────────────────────
LLM_PROVIDER=gemini

# Google Gemini (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-pro-preview
# Fallback models when the primary hits quota (comma-separated, in order).
# Set to empty to disable fallback.
GEMINI_FALLBACK_MODELS=gemini-3-pro-preview,gemini-3-flash-preview,gemini-2.5-pro,gemini-2.5-flash,gemini-2.5-flash-lite

# OpenAI (optional — only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (optional — only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ──────────────────────────────────────────────
# Summary language(s) — up to 2, comma-separated
# Examples: "English", "Chinese", "English,Chinese", "Japanese,English"
# ──────────────────────────────────────────────
SUMMARY_LANGUAGES=English

# Verify summary accuracy with a second LLM pass (true/false)
# Improves accuracy but doubles LLM cost per language
VERIFY_SUMMARY=false

# ──────────────────────────────────────────────
# Output mode: email | local | both
#   email — send summary via email (default)
#   local — save summary as markdown file only (no email credentials needed)
#   both  — send email AND save locally
# ──────────────────────────────────────────────
OUTPUT_MODE=email

# ──────────────────────────────────────────────
# Email settings (only required when OUTPUT_MODE is "email" or "both")
# ──────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here
# One or more recipient emails, comma-separated
RECIPIENT_EMAILS=your_email@gmail.com

# ──────────────────────────────────────────────
# Polling interval in seconds (default: 3600 = 1 hour)
# ──────────────────────────────────────────────
POLL_INTERVAL=3600

# ──────────────────────────────────────────────
# YouTube Search (optional — leave YOUTUBE_SEARCH_QUERIES empty to disable)
# Discovers new videos by keyword, beyond your configured channels.
# Uses YouTube Search API (100 units/call; daily limit 10,000 units).
# ──────────────────────────────────────────────
YOUTUBE_SEARCH_QUERIES=
# Max results per search query (1-50)
YOUTUBE_SEARCH_MAX_RESULTS=5
# How often to search, in seconds (14400 = every 4 hours)
YOUTUBE_SEARCH_INTERVAL=14400
# Max API units to spend on search per day (out of 10,000 total)
YOUTUBE_SEARCH_QUOTA_BUDGET=5000
# Pre-filter: skip videos whose title/description doesn't match any keyword
YOUTUBE_SEARCH_RELEVANCE_KEYWORDS=AI,artificial intelligence,machine learning,deep learning,LLM,GPT,neural network,transformer,AGI,GenAI
# Skip videos shorter than this (minutes) — filters out short clips
YOUTUBE_SEARCH_MIN_DURATION=10
# Max total search videos to process per search cycle (prevents overload)
YOUTUBE_SEARCH_MAX_TOTAL=15
# Minimum view count — skip low-traffic videos (0 = no filter)
YOUTUBE_SEARCH_MIN_VIEWS=1000
